#!/bin/bash
# Sudo askpass helper using pinentry-mac for native macOS GUI
# Used as fallback when Privileges.app TouchID is unavailable (e.g., clamshell mode)
# Caches password in macOS Keychain for 1 hour to avoid repeated prompts during debugging

set -euo pipefail

KEYCHAIN_SERVICE="sudo-askpass-cache"
KEYCHAIN_ACCOUNT="$(whoami)"

# Check if password is cached in keychain
check_cached_password() {
    local cached_password
    cached_password=$(security find-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w 2>/dev/null || true)

    if [[ -n "$cached_password" ]]; then
        echo "$cached_password"
        return 0
    fi

    return 1
}

# Prompt for password and cache it
prompt_and_cache_password() {
    local password

    PINENTRY=$(command -v pinentry-mac)

    if [[ -z "$PINENTRY" ]]; then
        # Fallback to osascript if pinentry-mac not found
        password=$(osascript -e 'Tell application "System Events" to display dialog "sudo requires your password:" default answer "" with hidden answer' -e 'text returned of result' 2>/dev/null)
    else
        # Use pinentry protocol to get password
        password=$({
            echo "SETTITLE Sudo Password Required"
            echo "SETDESC sudo requires your password to continue (cached for 1 hour)"
            echo "SETPROMPT Password:"
            echo "GETPIN"
        } | $PINENTRY 2>/dev/null | awk '/^D / {sub(/^D /, ""); print; exit}')
    fi

    if [[ -n "$password" ]]; then
        # Store in keychain (delete old entry first if exists)
        security delete-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" 2>/dev/null || true
        security add-generic-password -s "$KEYCHAIN_SERVICE" -a "$KEYCHAIN_ACCOUNT" -w "$password" -U 2>/dev/null

        echo "$password"
        return 0
    fi

    return 1
}

# Main logic
if check_cached_password; then
    exit 0
fi

prompt_and_cache_password
